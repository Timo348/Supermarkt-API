# Server
PORT=3000
NODE_ENV=production



# Beispiel-PLZs im Mannheimer Raum (ohne echte Privat-PLZs)
# Füge hier deine eigenen PLZs ein oder nutze zipcodes.local / .env.local
ZIP_CODES=68159,68161,68309,68519

# Cron-Ausdruck für automatische Aktualisierung (default: alle 6 Stunden)
REFRESH_CRON=0 */6 * * *

# Rate-Limit für API-Endpunkte (Anfragen pro Minute pro IP)
API_RATE_LIMIT_PER_MINUTE=60
