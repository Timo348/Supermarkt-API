# Server
PORT=3000
NODE_ENV=production

# Standorte (komma-getrennte PLZs im 10km-Radius um Mannheim, ohne Ludwigshafen)
ZIP_CODES=68159,68161,68163,68165,68167,68169,68199,68219,68229,68239,68259,68305,68307,68309,68519,68549,68535,68526,69198,69221,69214,68723,68782,68775,68804,68809,68766

# Cache-Ablaufzeit in Minuten
CACHE_TTL_MINUTES=60

# Cron-Ausdruck für automatische Aktualisierung (default: alle 6 Stunden)
REFRESH_CRON=0 */6 * * *

# Rate-Limit für API-Endpunkte (Anfragen pro Minute pro IP)
API_RATE_LIMIT_PER_MINUTE=60
